{
  "name": "meteordroid",
  "version": "0.5.0",
  "description": "MeteorDroid — local MCP stdio server providing Playwright-backed browser tools.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wpbiggs/MeteorDroid.git"
  },
  "bugs": {
    "url": "https://github.com/wpbiggs/MeteorDroid/issues"
  },
  "homepage": "https://github.com/wpbiggs/MeteorDroid#readme",
  "type": "module",
  "main": "dist/server.js",
  "bin": {
    "meteordroid": "bin/meteordroid.js"
  },
  "files": [
    "bin",
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "start": "tsx src/server.ts",
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "smoke": "tsx scripts/smoke.ts",
    "smoke:v2": "tsx scripts/smoke-v2.ts",
    "smoke:v3": "tsx scripts/smoke-v3.ts",
    "smoke:v4": "tsx scripts/smoke-v4.ts",
    "prepublishOnly": "npm run build",
    "postinstall": "playwright install chromium"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "playwright": "^1.48.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "@types/node": "^22.9.0"
  },
  "engines": {
    "node": ">=18.17"
  }
}
