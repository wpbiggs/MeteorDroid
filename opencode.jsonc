{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "browser-agent": {
      "type": "local",
      // Tip: use an absolute path so OpenCode can launch this from anywhere.
      "command": ["npx", "tsx", "/abs/path/to/opencode-browser-agent/src/server.ts"],
      "environment": {
        // mode: "ephemeral" | "persistent" | "cdp"
        "MINI_COMET_MODE": "persistent",
        "MINI_COMET_PROFILE_DIR": "~/.minicomet/profile",

        // For CDP mode (attach to a Chrome you launched with --remote-debugging-port):
        // "MINI_COMET_MODE": "cdp",
        // "MINI_COMET_CDP_URL": "http://localhost:9222",

        // If you want headless Chromium (ephemeral/persistent modes only):
        // "MINI_COMET_HEADLESS": "1"
      },
      "enabled": true
    }
  }
}
